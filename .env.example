# AI Agent Hub — Environment Configuration
# Copy this to .env and adjust values

# JWT secret for auth tokens (change in production!)
AUTH_JWT_SECRET=change-me-in-production

# Optional: Jira integration
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-jira-api-token

# Optional: GitLab integration
# GITLAB_URL=https://gitlab.example.com
# GITLAB_TOKEN=your-gitlab-private-token

# Optional: External database for data agent (read-only)
# EXTERNAL_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: Figma integration
# FIGMA_ACCESS_TOKEN=your-figma-access-token

# Optional: Docs project ID in GitLab
# DOCS_PROJECT_ID=123
